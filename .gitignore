.env
.env.local
.env.*.local
!.env.example
.compose-root
__pycache__/
*.pyc
.pytest_cache/
venv/
.venv/

# Cursor IDE — local workspace (plans, skills, rules); not part of public
# release trees. See docs/release/public-agpl-release-workflow.md.
.cursor/

# Plugin packages mounted at deploy time — not tracked in core.
# Any directory under orchestrator/plugins/ that is not part of core
# should be added here or kept outside this repository entirely.
orchestrator/plugins/*/
!orchestrator/plugins/__init__.py

# ai-workspace runtime content — keep directory structure, not runtime data
ai-workspace/inbox/*
!ai-workspace/inbox/.gitkeep
ai-workspace/outbox/*
!ai-workspace/outbox/.gitkeep
ai-workspace/approved/*
!ai-workspace/approved/.gitkeep
ai-workspace/review/*
!ai-workspace/review/.gitkeep
ai-workspace/backups/*.zip

# LibreChat — regenerated at runtime from models.yaml + Ollama; do not commit.
# Tracked template: config/librechat.coldstart.yaml
config/librechat.yaml

# Internal maintainer-only notes — not part of the distributed source tree
AUDIT-REPORT.md
REMEDIATION-PLAN.md
# Private local scratch (ignored by default). Exception: `docs/private/roadmap/` may be
# tracked for maintainer roadmap notes; that tree is omitted from the public export.
docs/private/**
!docs/private/roadmap/
!docs/private/roadmap/**

# IDE / OS
.idea/
*.swp
.DS_Store
docker-compose.override.yml
lumogis-data/
