# Lumogis – copy to .env and fill in values

# --- LLM ---
ANTHROPIC_API_KEY=
LITELLM_URL=http://litellm:4000

# --- File system ---
FILESYSTEM_ROOT=

# --- LibreChat / MongoDB ---
MONGO_URI=mongodb://mongodb:27017/librechat
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production

# --- Backend selection ---
VECTOR_STORE_BACKEND=qdrant
METADATA_STORE_BACKEND=postgres
EMBEDDER_BACKEND=ollama
RERANKER_BACKEND=bge
EXTRACTOR_OCR_ENABLED=true

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Postgres ---
POSTGRES_USER=lumogis
POSTGRES_PASSWORD=lumogis-dev
POSTGRES_DB=lumogis
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Ollama / Embedder ---
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# --- Reranker ---
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Graph plugin (ignored if plugins/graph/ absent) ---
FALKORDB_URL=redis://falkordb:6379
