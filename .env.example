# Lumogis — copy to .env and fill in values.
# User install: git clone → cp .env.example .env → docker compose up -d
# No make, no setup.sh required. See README for Getting Started.

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=lumogis
# Base compose file — GPU support is opt-in, see GPU acceleration section below.
COMPOSE_FILE=docker-compose.yml

# --- LLM (add API keys for the providers you want to use) ---
ANTHROPIC_API_KEY=
# --- Optional cloud providers (enable in dashboard Settings, then add key here) ---
# OPENAI_API_KEY=        # ChatGPT — https://platform.openai.com/api-keys
# XAI_API_KEY=           # Grok    — https://console.x.ai/
# PERPLEXITY_API_KEY=    # Perplexity — https://www.perplexity.ai/settings/api
# GEMINI_API_KEY=        # Gemini  — https://aistudio.google.com/app/apikey
# MISTRAL_API_KEY=       # Mistral — https://console.mistral.ai/api-keys/
# MODELS_CONFIG=/app/models.yaml  # override path to models.yaml inside container

# --- File system ---
# Folder Lumogis indexes. Default is ./lumogis-data (inside this repo, persistent).
# Change to an absolute path if you want to index an existing folder (e.g. /home/alice/Documents).
# You can also change it later in the dashboard: Settings → Indexed Folder.
# Windows users: use forward slashes (e.g. C:/Users/alice/lumogis-data).
FILESYSTEM_ROOT=./lumogis-data

# --- LibreChat / MongoDB ---
APP_TITLE=Lumogis
MONGO_URI=mongodb://mongodb:27017/librechat
# Email/password sign-up on the login page (LibreChat). Set false for invite-only / production.
ALLOW_REGISTRATION=true
# Optional: footer link in LibreChat to the Lumogis dashboard (change URL for reverse-proxy setups)
# CUSTOM_FOOTER=[Dashboard](http://localhost:8000/dashboard)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production

# --- Backend selection ---
VECTOR_STORE_BACKEND=qdrant
METADATA_STORE_BACKEND=postgres
EMBEDDER_BACKEND=ollama
# Reranker: improves search quality but downloads ~400 MB from HuggingFace on first start.
# Set to "bge" to enable (requires NVIDIA GPU for best performance, works on CPU).
# Set to "none" to disable (faster cold start, slightly lower search quality).
RERANKER_BACKEND=none
EXTRACTOR_OCR_ENABLED=true

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Postgres ---
POSTGRES_USER=lumogis
POSTGRES_PASSWORD=lumogis-dev
POSTGRES_DB=lumogis
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Ollama / Embedder ---
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
# Comma-separated chat model(s) pulled after the embedder. Default: Llama 3.2 3B (~2 GB).
# Gemma 4 and the full Ollama library are listed in the dashboard; pull what you need.
# OLLAMA_EXTRA_MODELS=gemma4:e2b
# Set empty to skip: OLLAMA_EXTRA_MODELS=
OLLAMA_EXTRA_MODELS=llama3.2:3b

# LLM used for signal summarisation / scoring (must match a models.yaml alias).
# SIGNAL_LLM_MODEL=llama

# --- Reranker ---
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Graph plugin (only needed with docker-compose.falkordb.yml) ---
# FALKORDB_URL=redis://falkordb:6379

# --- stack-control (restart sidecar) ---
# Generate a long random string: openssl rand -hex 32
RESTART_SECRET=change-me-to-a-random-secret
# STACK_CONTROL_URL=http://stack-control:9000  # default; change if using a custom port

# --- GPU acceleration ---
# Uncomment the line below to enable NVIDIA GPU acceleration for Ollama.
# Requires NVIDIA Container Toolkit: https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/
# On Linux: verify with: docker run --rm --gpus all nvidia/cuda:12.0-base nvidia-smi
# On Windows: GPU passthrough via WSL2 backend (see docs/gpu-setup.md)
# On macOS: Not supported by Docker Desktop (Apple Silicon GPU not exposed to containers)
#
# COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml

# --- Signals / Digest ---
# NOTIFIER_BACKEND=ntfy     # default: null (no push notifications)
# NTFY_URL=http://ntfy:80   # set if using the optional ntfy service in docker-compose.yml
# NTFY_TOPIC=lumogis
# NTFY_TOKEN=               # optional bearer token if ntfy requires auth
# SIGNAL_DIGEST_ENABLED=true
# SIGNAL_DIGEST_INTERVAL=86400   # seconds between digests (default: daily)
# SIGNAL_DIGEST_COUNT=5          # max signals included per digest
