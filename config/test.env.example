# Lumogis — deterministic defaults for public RC / CI integration tests.
#
# Usage:
#   COMPOSE_PROFILES= COMPOSE_FILE=docker-compose.yml:docker-compose.test.yml:docker-compose.public-rc-stack.yml \
#     docker compose --env-file config/test.env.example up -d
#
# Playwright (make test-ui / verify-public-rc):
#   export PLAYWRIGHT_BASE_URL=http://127.0.0.1
#   # Stack must serve Lumogis Web via Caddy on that origin (port 80 → http://127.0.0.1).
#
# Integration pytest started inside the orchestrator container (make test-integration)
# uses LUMOGIS_WEB_BASE_URL=http://caddy automatically; on the host, defaults below apply.

# --- Compose / profiles ---
COMPOSE_PROJECT_NAME=lumogis-test
COMPOSE_FILE=docker-compose.yml:docker-compose.test.yml:docker-compose.public-rc-stack.yml
# Faster smoke stack: skip LibreChat + Mongo unless you opt back in.
COMPOSE_PROFILES=

# --- Web smoke ---
PLAYWRIGHT_BASE_URL=http://127.0.0.1
LUMOGIS_WEB_BASE_URL=http://127.0.0.1
LUMOGIS_API_URL=http://127.0.0.1:8000

# Same-origin cookie CSRF for Playwright + host pytest hitting http://127.0.0.1 through Caddy.
LUMOGIS_PUBLIC_ORIGIN=http://127.0.0.1

# --- Orchestrator (lumogis-test stack — AUTH_ENABLED=true for login + integration Bearer) ---
AUTH_ENABLED=true
# Deterministic non-production secrets for the disposable compose stack only.
AUTH_SECRET=aabbccddeeff0011223344556677889900aabbccddeeff00112233445566778899
LUMOGIS_CREDENTIAL_KEY=dGwtx7svqjT1EJJNtroYkmO3wICl7ekInYOBlHNLBVA=
GRAPH_MODE=inprocess
CAPABILITY_SERVICE_URLS=
MCP_AUTH_TOKEN=

# Bootstrap admin when the users table is empty (first boot of a fresh test volume).
# Email must satisfy LoginRequest validation (use example.com — not reserved/special-use TLDs like `.test`).
LUMOGIS_BOOTSTRAP_ADMIN_EMAIL=rc-smoke-not-real@example.com
LUMOGIS_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe12345!

# Playwright + host integration pytest login (≥12 chars). Override in the environment if needed.
LUMOGIS_WEB_SMOKE_EMAIL=rc-smoke-not-real@example.com
LUMOGIS_WEB_SMOKE_PASSWORD=ChangeMe12345!

# --- Speech / push / notify (no live sidecars for the default RC gate) ---
STT_BACKEND=none
NOTIFIER_BACKEND=
# WEBPUSH_VAPID_PUBLIC_KEY=
# WEBPUSH_VAPID_PRIVATE_KEY=

# --- Public RC full stack (docker-compose.public-rc-stack.yml) ---
# FalkorDB + lumogis-graph + mock capability — host ports for integration probes.
KG_MEM_LIMIT=2g
FALKORDB_URL=redis://falkordb:6379
MOCK_CAPABILITY_SHARED_SECRET=rc-mock-cap-deterministic-secret-do-not-use-prod
LUMOGIS_GRAPH_HEALTH_URL=http://127.0.0.1:18001/health
LUMOGIS_MOCK_CAPABILITY_BASE_URL=http://127.0.0.1:18080

# Core test-only chat streaming stub (see orchestrator/routes/api_v1/chat.py).
LUMOGIS_RC_CHAT_STUB=true
LUMOGIS_RC_CHAT_STUB_REPLY=RC_CHAT_STUB_ACK

# --- Compose interpolation (required keys referenced by base compose services) ---
POSTGRES_USER=lumogis
POSTGRES_PASSWORD=lumogis-dev
POSTGRES_DB=lumogis
MONGO_URI=mongodb://mongodb:27017/librechat
JWT_SECRET=test-jwt-secret-placeholder-change-for-non-test-use-only
JWT_REFRESH_SECRET=test-jwt-refresh-secret-placeholder-change-for-non-test-use-only
RESTART_SECRET=test-restart-secret-placeholder
